{
  "name": "ballin-scripts",
  "version": "1.0.0",
  "description": "Useful scripts to save time",
  "scripts": {
    "lint": "eslint . --ext .js,.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "mocha",
    "test": "npm run lint && npm run typecheck && npm run test:unit"
  },
  "engines": {
    "node": ">=24.12"
  },
  "mocha": {
    "extension": [
      "js",
      "ts"
    ],
    "require": [
      "test/setup.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JBallin/ballin-scripts.git"
  },
  "author": {
    "name": "JBallin",
    "url": "https://medium.com/@PrintSupWorld"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JBallin/ballin-scripts/issues"
  },
  "homepage": "https://github.com/JBallin/ballin-scripts#readme",
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "chai": "^4.3.6",
    "eslint": "^8.9.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.4",
    "mocha": "^11.7.2",
    "typescript": "^6.0.3"
  }
}
