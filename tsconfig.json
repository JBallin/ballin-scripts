{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "erasableSyntaxOnly": true,
    "forceConsistentCasingInFileNames": true,
    "module": "CommonJS",
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node", "mocha"]
  },
  "include": [
    "analytics-worker/report.ts",
    "analytics-worker/reset.ts",
    "commands/**/*.ts",
    "config/**/*.ts",
    "test/**/*.ts"
  ]
}
