{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "module": "CommonJS",
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node", "mocha"]
  },
  "include": [
    "config/**/*.ts",
    "test/config.test.ts",
    "test/setup.ts"
  ]
}
