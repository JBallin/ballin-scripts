#!/usr/bin/env bash

### DELETE SYMLINKS
printf '\n%s\n' "It's been real..."

# Include current and legacy install locations so upgrades remain uninstallable.
# Tests can relocate system directories without granting access to the real ones.
system_root="${BALLIN_UNINSTALL_TEST_SYSTEM_ROOT:-}"
bin_dirs=("$HOME/.local/bin" "$system_root/usr/local/bin" "$system_root/opt/homebrew/bin")

add_bin_dir() {
  local candidate="$1"
  local bin_dir
  for bin_dir in "${bin_dirs[@]}"; do
    if [ "$bin_dir" = "$candidate" ]; then
      return
    fi
  done
  bin_dirs+=("$candidate")
}

if [ -x "$(command -v brew)" ]; then
  brew_prefix="$(brew --prefix)"
  case "$brew_prefix" in
    /usr/local|/opt/homebrew) brew_prefix="$system_root$brew_prefix" ;;
  esac
  add_bin_dir "$brew_prefix/bin"
fi

for bin in "$HOME/.ballin-scripts/bin/"*; do
  for bin_dir in "${bin_dirs[@]}"; do
    link="$bin_dir/${bin##*/}"
    if [ -L "$link" ] && [ "$(readlink "$link")" = "$bin" ]; then
      rm "$link"
    fi
  done
done
printf '%s\n' 'Deleted symlinked binaries'

rm -rf "$HOME/.ballin-scripts"
printf '%s\n\n' 'PEACE! You still ballin tho...'
